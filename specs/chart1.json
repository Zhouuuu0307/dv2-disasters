{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 280,
  "title": {
    "text": "Natural disasters recorded in Australia (1960–2024)",
    "subtitle": "Number of significant events per year by disaster type",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "data": {"url": "data/chart1_timeline.csv"},
  "mark": {"type": "area", "interpolate": "monotone"},
  "encoding": {
    "x": {
      "field": "year", "type": "ordinal",
      "axis": {"labelAngle": -45, "tickCount": 10, "title": null}
    },
    "y": {
      "field": "event_count", "type": "quantitative",
      "stack": "zero",
      "axis": {"title": "Number of events", "grid": true}
    },
    "color": {
      "field": "disaster_type", "type": "nominal",
      "title": "Disaster type",
      "scale": {
        "domain": ["Bushfire","Flood","Storm/Cyclone","Drought","Heatwave","Earthquake","Landslide","Other"],
        "range":  ["#D85A30","#378ADD","#7F77DD","#BA7517","#E24B4A","#888780","#1D9E75","#B4B2A9"]
      }
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "disaster_type", "type": "nominal", "title": "Type"},
      {"field": "event_count", "type": "quantitative", "title": "Events"}
    ]
  }
}
