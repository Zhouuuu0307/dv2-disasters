{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 420,

  "title": {
    "text": "Insured disaster losses by state (1980–2026)",
    "subtitle": "Normalised to 2022 AUD billions — ICA catastrophe data",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "start"
  },

  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 700,
    "translate": [350, 210]
  },

  "layer": [
    {
      "data": {
        "url": "https://Zhouuuu0307.github.io/dv2-disasters/data/australia_states_simple.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#d8d5cc",
        "stroke": "#ffffff",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "https://Zhouuuu0307.github.io/dv2-disasters/data/australia_states_simple.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.state_name",
          "as": "state_name"
        },
        {
          "lookup": "state_name",
          "from": {
            "data": {
              "url": "https://Zhouuuu0307.github.io/dv2-disasters/data/chart4_choropleth.csv"
            },
            "key": "state_name",
            "fields": ["total_loss_b", "event_count", "total_claims"]
          }
        },
        {
          "filter": "isValid(datum.total_loss_b)"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "total_loss_b",
          "type": "quantitative",
          "title": "Loss (A$B)",
          "scale": {
            "scheme": "orangered",
            "domain": [0, 35]
          },
          "legend": {
            "orient": "right"
          }
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "total_loss_b",
            "type": "quantitative",
            "title": "Loss (A$B)",
            "format": ".2f"
          },
          {
            "field": "event_count",
            "type": "quantitative",
            "title": "Events"
          },
          {
            "field": "total_claims",
            "type": "quantitative",
            "title": "Claims",
            "format": ","
          }
        ]
      }
    }
  ],

  "config": {
    "background": "#faf9f6",
    "view": {
      "stroke": null
    }
  }
}
