{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 680,
  "height": 320,
  "title": {
    "text": "Rising temperatures and more disasters (1960\u20132024)",
    "subtitle": "Australia's annual temperature anomaly (bars) vs recorded disaster events (line)",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "data": {
    "url": "../data/chart11_temp_disasters.csv"
  },
  "transform": [
    {
      "filter": "datum.year >= 1967"
    }
  ],
  "params": [
    {
      "name": "year_range",
      "value": [
        1967,
        2024
      ],
      "bind": {
        "input": "range",
        "min": 1967,
        "max": 2024,
        "step": 1,
        "name": "Year range start: "
      }
    }
  ],
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "labelAngle": -45,
            "tickCount": 10,
            "title": null
          }
        },
        "y": {
          "field": "temp_anomaly_c",
          "type": "quantitative",
          "axis": {
            "title": "Temp anomaly (\u00b0C vs 1961\u20131990)",
            "titleColor": "#D85A30"
          },
          "scale": {
            "domain": [
              -1,
              2
            ]
          }
        },
        "color": {
          "condition": {
            "test": "datum.temp_anomaly_c >= 0",
            "value": "#D85A30"
          },
          "value": "#378ADD"
        },
        "opacity": {
          "condition": {
            "test": "datum.year >= year_range",
            "value": 0.85
          },
          "value": 0.15
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "temp_anomaly_c",
            "type": "quantitative",
            "title": "Temp anomaly (\u00b0C)",
            "format": ".2f"
          },
          {
            "field": "event_count",
            "type": "quantitative",
            "title": "Disasters recorded"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#7F77DD",
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "event_count",
          "type": "quantitative",
          "axis": {
            "title": "Disaster events per year",
            "titleColor": "#7F77DD"
          }
        },
        "opacity": {
          "condition": {
            "test": "datum.year >= year_range",
            "value": 1.0
          },
          "value": 0.2
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "color": "#7F77DD",
        "size": 40,
        "filled": true
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "event_count",
          "type": "quantitative"
        },
        "opacity": {
          "condition": {
            "test": "datum.year >= year_range",
            "value": 1.0
          },
          "value": 0.2
        }
      }
    }
  ]
}